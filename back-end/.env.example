# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
POSTGRES_DB=app_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# Derived from the above — used by the API container
DATABASE_URL=postgresql://app_user:changeme@localhost:5432/app_db

# Frontend origin allowed by CORS (no trailing slash)
CORS_ORIGIN=http://localhost:3001

# JWT — generate strong random secrets for real environments:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=generate_with__node_-e__console.log(require('crypto').randomBytes(64).toString('hex'))
JWT_REFRESH_SECRET=generate_with__node_-e__console.log(require('crypto').randomBytes(64).toString('hex'))

# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key_here
